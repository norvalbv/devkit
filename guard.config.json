{
  "scanRoots": ["cli", "gate-engine"],
  "sourceExtensions": ["mjs", "js"],
  "fanoutCap": 12,
  "indexPath": ".search-code/index.db",
  "review": {
    "backendRoots": ["cli", "gate-engine"],
    "frontendRoots": [],
    "trustBoundaries": "devkit is a CLI + portable gate-engine, not a hosted app — no server/client split. Its trust model is W-3: devkit ships inside the consumer's node_modules and EXECUTES in a repo it does not own, so every path it resolves must be consumer-cwd-relative, never __dirname, and synced assets (skills/agents/gate scripts) must read layout from the consumer's guard.config.json, never hardcode a stack's directory tree."
  },
  "structure": {
    "trees": [
      {
        "name": "cli",
        "root": "cli",
        "sourceExtensions": ["mjs", "js"],
        "entryAllowlist": ["index.mjs"],
        "libDomains": { "lib": ["generate", "husky", "install", "ship"] },
        "grammar": {
          "files": ["index.mjs"],
          "folders": {
            "commands": { "files": ["{kebab}", "{kebab_test}"] },
            "lib": {
              "files": ["{kebab}", "{kebab_test}"],
              "domainGate": "lib",
              "recurse": "kebabModule"
            }
          },
          "rules": {
            "kebabModule": {
              "folderName": "{kebab_dir}",
              "files": ["{kebab}", "{kebab_test}", "{json}"],
              "recurse": "kebabModule"
            }
          }
        }
      },
      {
        "name": "gate-engine",
        "root": "gate-engine",
        "sourceExtensions": ["mjs", "js"],
        "entryAllowlist": ["config.mjs"],
        "ignoredDirs": ["eval"],
        "libDomains": {
          "@root": [
            "co-occurrence",
            "decisions",
            "fallow",
            "judge",
            "ratchets",
            "search-tool",
            "sentry",
            "structure"
          ]
        },
        "grammar": {
          "files": ["config.mjs"],
          "domainGate": "@root",
          "recurse": "engineModule",
          "rules": {
            "engineModule": {
              "folderName": "{kebab_dir}",
              "files": ["{kebab}", "{kebab_test}", "{json}"],
              "recurse": "engineModule"
            }
          }
        }
      }
    ],
    "walls": []
  }
}
