{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "skipLibCheck": true,
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["cli/**/*.mjs", "gate-engine/**/*.mjs"],
  "//": "Typecheck shipped source only. Tests are validated by running them (vitest); templates import consumer-only peer deps (see their @ts-nocheck).",
  "exclude": ["node_modules", "templates", "**/*.test.mjs", "**/__tests__/**"]
}
