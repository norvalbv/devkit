node_modules
.DS_Store

# devkit's own gate artifacts (regenerated; not source)
.fallow/
.search-code/
# ship/gate caches under .devkit/ (regenerated, per-branch/-tree keyed; tracked manifests stay tracked)
.devkit/prefix-cache.json
.devkit/decisions-verdict-cache.json
.devkit/review-cache.json
.devkit/review-progress-*.json
.devkit/last-ship-gates-*.log
.devkit/reconcile-manifest.json
# decision-log embedding cache (query); rebuildable via `guard-decisions reindex`. docs/decisions/ IS committed.
.decisions/
# decisions-eval baseline: no baseline ships — each consumer generates theirs with --baseline
gate-engine/decisions/eval/results.baseline.json
# decisions-eval run ledger (local telemetry; the anti-Goodhart record of runs against the corpus)
gate-engine/decisions/eval/runs.log
# critique-eval: ledger + per-run transcripts are local telemetry. NOTE: its results.baseline.json
# IS committed (sc-1059 requires a committed baseline) — do not add it here.
gate-engine/critique/eval/runs.log
gate-engine/critique/eval/transcripts/

# eslint-plugin-project-structure cache
projectStructure.cache.json

# compiled output — built + committed ONLY on release commits/tags (see cli/commands/release). Ignored on main + feature branches so day-to-day diffs stay source-only.
dist/

# npm pack output (build artifact)
*.tgz
