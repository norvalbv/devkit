node_modules
.DS_Store

# devkit's own gate artifacts (regenerated; not source)
.fallow/
.search-code/
# qavis pass-receipt: content-addressed cache written by `qavis qa` (specific file — .qavis/recipe.json stays tracked)
.qavis/receipt.json
# ship/review/gate caches under .devkit/ (regenerated, per-run/-branch/-tree keyed; tracked manifests stay tracked)
.devkit/prefix-cache.json
.devkit/decisions-verdict-cache.json
.devkit/review-cache.json
.devkit/review-progress-*.json
.devkit/review-runs/
.devkit/last-ship-gates-*.log
.devkit/reconcile-manifest.json
# ...and the `.generation` sidecars those caches write. Untracked-but-not-ignored, they were enough
# to make `devkit release` refuse ("working tree not clean") in the repo that ships devkit itself.
.devkit/*.generation
# decision-log embedding cache (query); rebuildable via `guard-decisions reindex`. docs/decisions/ IS committed.
.decisions/
# decisions-eval baseline: no baseline ships — each consumer generates theirs with --baseline
gate-engine/decisions/eval/results.baseline.json
# decisions-eval run ledger (local telemetry; the anti-Goodhart record of runs against the corpus)
gate-engine/decisions/eval/runs.log
# critique-eval: ledger + per-run transcripts are local telemetry. NOTE: its results.baseline.json
# IS committed (sc-1059 requires a committed baseline) — do not add it here.
gate-engine/critique/eval/runs.log
gate-engine/critique/eval/transcripts/

# eslint-plugin-project-structure cache
projectStructure.cache.json

# compiled output — built + committed ONLY on release commits/tags (see cli/commands/release). Ignored on main + feature branches so day-to-day diffs stay source-only.
dist/

# npm pack output (build artifact)
*.tgz

# completeness-eval working data (bench outputs; the corpus + baseline ARE committed)
gate-engine/review/eval/runs.log
gate-engine/review/eval/candidates.jsonl
gate-engine/review/eval/transcripts/

# reviewer-eval working data (bench outputs; the corpus IS committed)
gate-engine/review/eval/reviewers/*.log
gate-engine/review/eval/reviewers/results.baseline.json
gate-engine/review/eval/reviewers/candidates.jsonl
gate-engine/review/eval/reviewers/progress-*.jsonl

# conventions-eval: ledger + per-run transcripts are local telemetry (mirrors critique-eval).
# NOTE: results.baseline.json is NOT committed YET (no live run has been performed — see
# README's "Results — baseline history" section); once a first --baseline run lands it SHOULD be
# committed like completeness/critique's, so do not add it here.
gate-engine/review/eval/conventions/runs.log
gate-engine/review/eval/conventions/transcripts/
gate-engine/edge-cases/eval/raw/
gate-engine/edge-cases/eval/cases.jsonl
