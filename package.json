{
  "name": "@norvalbv/devkit",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Single source-of-truth devkit: shared Biome/TS configs + portable governance gate-engine + setup-wizard CLI. Consumed via `bun add git+ssh://git@github.com/norvalbv/devkit.git#<tag>`.",
  "exports": {
    "./biome/base": "./biome/base.jsonc",
    "./biome/react": "./biome/react.jsonc",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/next": "./tsconfig/next.json",
    "./tsconfig/node": "./tsconfig/node.json",
    "./gate-engine/config": "./gate-engine/config.mjs"
  },
  "bin": {
    "devkit": "./cli/index.mjs",
    "guard-decisions": "./gate-engine/decisions/cli.mjs",
    "guard-dup": "./gate-engine/co-occurrence/matcher.mjs",
    "guard-clone": "./gate-engine/co-occurrence/clone-detector.mjs",
    "guard-fanout": "./gate-engine/ratchets/folder-fanout.mjs",
    "guard-size": "./gate-engine/ratchets/size-disable.mjs"
  },
  "files": [
    "cli",
    "templates",
    "biome",
    "tsconfig",
    "gate-engine",
    "skills"
  ],
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "jscpd": "^4.2.4"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1"
  }
}
